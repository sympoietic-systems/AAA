# AAA Environment Configuration
# Copy to .env and fill in your values

# ── LLM Provider ──────────────────────────────────
# Which provider to use: openrouter | deepseek
AAA_LLM_PROVIDER=openrouter

# OpenRouter API key (https://openrouter.ai/keys)
# Required when AAA_LLM_PROVIDER=openrouter
AAA_LLM_API_KEY=your_openrouter_api_key_here

# DeepSeek API key (https://platform.deepseek.com/api_keys)
# Required when AAA_LLM_PROVIDER=deepseek
AAA_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Thinking Mode (DeepSeek-v4-pro / v4-flash) ──────
# Enable chain-of-thought reasoning before each response.
# When enabled, temperature/top_p are ignored by the model.
# AAA_LLM_THINKING=true
# AAA_LLM_REASONING_EFFORT=high   # high | max

# ── Optional overrides ────────────────────────────
# For openrouter:  AAA_LLM_MODEL=deepseek/deepseek-chat
# For deepseek:    AAA_LLM_MODEL=deepseek-v4-pro
#                  Available: deepseek-v4-pro, deepseek-v4-flash
#                  (deepseek-chat deprecated 2026/07/24)
#
# AAA_LLM_API_BASE=https://api.deepseek.com
# AAA_SERVER_HOST=127.0.0.1
# AAA_SERVER_PORT=8000
