# AAA Environment Configuration
# Copy to .env and fill in your values

# ── LLM Provider ──────────────────────────────────
# Comma-separated list of models to try in priority order.
# Supports google_router/, deepseek_router/, and openrouter_router/ prefixes.
# Prioritizes Gemini 2.5 Pro & 1.5 Pro (advanced but limited to 2 RPM on free keys), 
# falls back to Gemini 2.5 Flash, and ultimately falls back to DeepSeek v4 Pro.
AAA_LLM_MODELS=google_router/gemini-2.5-pro,google_router/gemini-1.5-pro,google_router/gemini-2.5-flash,deepseek_router/deepseek-v4-pro

# OpenRouter API key (https://openrouter.ai/keys)
AAA_LLM_API_KEY=your_openrouter_api_key_here

# DeepSeek API key (https://platform.deepseek.com/api_keys)
AAA_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Thinking Mode (DeepSeek-v4-pro / v4-flash) ──────
# Enable chain-of-thought reasoning before each response.
# When enabled, temperature/top_p are ignored by the model.
# AAA_LLM_THINKING=true
# AAA_LLM_REASONING_EFFORT=high   # high | max

# ── Optional overrides ────────────────────────────
# AAA_LLM_MODEL=google_router/gemini-2.5-pro
# AAA_LLM_API_BASE=https://api.deepseek.com
# AAA_SERVER_HOST=127.0.0.1
# AAA_SERVER_PORT=8000

# -- Simple Authentication (optional) --
# If set, secures the application by prompting for this password on load.
# AAA_PASSWORD=your_secure_password_here


# Google API keys for Gemini models (comma-separated for rotation fallback)
# AAA_GOOGLE_API_KEY=AIzaSyDLYF3wt...

# ── Background Tasks Model ────────────────────────
# Models are tried in order. If one is rate-limited, the next is used.
# Supports google_router/ and openrouter_router/ prefixes.
# When all are exhausted, falls back to AAA_BACKGROUND_FALLBACK_MODEL.
AAA_BACKGROUND_MODELS=google_router/gemini-2.5-flash,google_router/gemini-1.5-flash,openrouter_router/google/gemma-4-26b-a4b-it:free,openrouter_router/nvidia/nemotron-nano-9b-v2:free
AAA_BACKGROUND_API_BASE=https://openrouter.ai/api/v1
# AAA_BACKGROUND_API_KEY=  # optional: separate key for background tasks
AAA_BACKGROUND_FALLBACK_MODEL=openrouter_router/google/gemma-4-26b-a4b-it:free

# -- Vision Fallback Model --
# Model with vision capabilities for image understanding
AAA_VISION_MODEL=google_router/gemini-2.5-flash
AAA_VISION_API_BASE=https://openrouter.ai/api/v1
# AAA_VISION_API_KEY=  # optional: separate key for vision tasks

# -- Embeddings (optional) --
# AAA_EMBEDDING_OFFLINE = true
# AAA_EMBEDDING_MODEL=all-MiniLM-L6-v2
# AAA_EMBEDDING_DEVICE=gpu
# AAA_EMBEDDING_CACHE_DIR=./embedding_cache

# -- LLM Structural Scorer (optional) --
AAA_LLM_SCORER_ENABLED=true
AAA_STRUCTURAL_MODELS=google_router/gemini-2.5-flash,google_router/gemini-1.5-flash,openrouter_router/google/gemma-4-26b-a4b-it:free,openrouter_router/nvidia/nemotron-nano-9b-v2:free
# AAA_STRUCTURAL_API_KEY=  # optional: separate key for structural tasks
AAA_STRUCTURAL_FALLBACK_MODEL=openrouter_router/google/gemma-4-26b-a4b-it:free

# ── Autopoietic Dream Daemon (Machine Sleep Engine) ─
# AAA_DAEMON_ENABLED=true
# AAA_DAEMON_CHECK_INTERVAL=60            # seconds between trigger evaluations (default: 60)
# AAA_DAEMON_IDLE_THRESHOLD=1800          # seconds of human inactivity before dreaming (e.g., 30 mins)
# AAA_DAEMON_MIN_DREAM_INTERVAL=3600      # minimum seconds between successful dreams (e.g., 1 hour)
# AAA_DAEMON_MAX_DAILY_DREAMS=10          # max dreams per 24 hours (default: 10)
# AAA_DAEMON_DRIFT_COEFFICIENT=0.00001    # decay speed of beliefs during sleep